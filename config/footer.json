{
  "variant": "powerline",
  "theme": {
    "background": "#24283b",
    "accent": "#7aa2f7",
    "text": "#c0caf5",
    "success": "#9ece6a"
  },
  "segments": [
    {
      "type": "model",
      "style": "slant_right"
    },
    {
      "type": "usage",
      "options": {
        "show_cache": true,
        "detailed": true,
        "show_costs": true,
        "breakdown_costs": true,
        "shorten_numbers": true,
        "labels": {
          "input": "󰌒 ",
          "output": "󰌓 ",
          "cache": " "
        }
      }
    },
    {
      "type": "git_info"
    }
  ]
}
