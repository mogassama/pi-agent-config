{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-sonnet-4-6",
  "activeFooter": "pi-powerline-footer",
  "packages": ["npm:pi-subagents", "npm:pi-powerline-footer"],
  "ui": {
    "footer": {
      "variant": "powerline",
      "theme": {
        "background": "#24283b",
        "accent": "#7aa2f7",
        "text": "#c0caf5",
        "success": "#9ece6a"
      },
      "segments": [
        { "type": "model", "style": "slant_right" },
        { "type": "thinking" },
        { "type": "project" },
        { "type": "git" },
        {
          "type": "usage",
          "options": {
            "show_cache": true,
            "detailed": true,
            "show_costs": true,
            "breakdown_costs": true,
            "shorten_numbers": true,
            "labels": {
              "input": "󰌒 ",
              "output": "󰌓 ",
              "cache": " "
            }
          }
        }
      ]
    }
  },
  "subagents": {
    "agentOverrides": {
      "planner": {
        "model": "anthropic/claude-sonnet-4-6",
        "thinking": "high",
        "skills": [
          "dataeng-architecture",
          "gcp-engineering",
          "dbt-engineering",
          "iac-terraform"
        ],
        "inheritProjectContext": true
      },
      "worker": {
        "model": "anthropic/claude-sonnet-4-6",
        "thinking": "medium",
        "skills": [
          "python-engineering",
          "airflow-engineering",
          "dbt-engineering",
          "data-quality",
          "iac-terraform"
        ],
        "inheritProjectContext": true
      },
      "reviewer": {
        "model": "anthropic/claude-sonnet-4-6",
        "thinking": "medium",
        "skills": [
          "code-review",
          "python-engineering",
          "sql-engineering",
          "data-quality",
          "iac-terraform",
          "technical-writing"
        ],
        "inheritProjectContext": true
      },
      "oracle": {
        "model": "anthropic/claude-sonnet-4-6",
        "thinking": "high",
        "skills": ["dataeng-architecture", "iac-terraform"]
      },
      "scout": {
        "model": "anthropic/claude-haiku-4-5",
        "skills": ["python-engineering"]
      }
    }
  },
  "defaultThinkingLevel": "medium"
}
